{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "mdreader",
	"version": "0.1.0",
	"identifier": "com.mdreader.app",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"app": {
		"windows": [
			{
				"title": "mdreader",
				"width": 800,
				"height": 600,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": ["dmg"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
