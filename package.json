		"@tiptap/extension-task-list": "3.22.3",
		"@tiptap/pm": "3.22.3",
		"@tiptap/starter-kit": "3.22.3",
		"codemirror": "6.0.2",
		"lowlight": "3.3.0",
		"tiptap-markdown": "0.9.0",
		"yaml": "2.8.3"
